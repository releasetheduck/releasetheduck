---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing — ${SITE_TITLE}`} description="All posts" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Writing</h1>
			<ul class="post-list">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<div class="post-meta">
								<FormattedDate date={post.data.pubDate} />
								{post.data.type && (
									<span class={`post-type ${post.data.type}`}>{post.data.type}</span>
								)}
								{post.data.rating && (
									<span class="rating">{post.data.rating}/10</span>
								)}
							</div>
							<h3>{post.data.title}</h3>
							{post.data.artist && (
								<p class="artist">{post.data.artist}{post.data.album ? ` — ${post.data.album}` : ''}</p>
							)}
							{post.data.genre && (
								<div class="genres">
									{post.data.genre.map((g: string) => (
										<span class="genre-tag">{g}</span>
									))}
								</div>
							)}
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-bottom: 2em;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li {
		border-bottom: 1px solid var(--border);
	}
	.post-list li a {
		display: block;
		padding: 1.5em 0;
		text-decoration: none;
		transition: all 0.2s;
	}
	.post-list li a:hover {
		padding-left: 1em;
		background: var(--bg-surface);
		margin: 0 -1em;
		padding-right: 1em;
		border-radius: var(--radius);
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.8em;
		font-family: var(--font-display);
		font-size: 0.75em;
		color: var(--text-dim);
		margin-bottom: 0.3em;
	}
	h3 {
		font-size: 1.2em;
		color: var(--text);
		margin: 0 0 0.2em 0;
	}
	.artist {
		font-family: var(--font-display);
		font-size: 0.85em;
		color: var(--text-muted);
		margin: 0 0 0.5em 0;
	}
	.genres {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3em;
	}
</style>
