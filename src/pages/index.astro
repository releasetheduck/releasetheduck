---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = posts.slice(0, 10);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Pato Escobar</h1>
				<p class="tagline">mi pequeño espacio en la internec para escribir de música :)</p>
			</section>

			<section class="posts">
				<h2 class="section-title">Lo nuevo</h2>
				<ul>
					{latestPosts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} />
									{post.data.type && (
										<span class={`post-type ${post.data.type}`}>{post.data.type}</span>
									)}
								</div>
								<h3 class="post-title">{post.data.title}</h3>
								{post.data.artist && (
									<p class="post-artist">{post.data.artist}{post.data.album ? ` — ${post.data.album}` : ''}</p>
								)}
								{post.data.rating && (
									<span class="rating">{post.data.rating}/10</span>
								)}
								<p class="post-description">{post.data.description}</p>
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="view-all">View all posts →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 4em 0 3em 0;
		border-bottom: 1px solid var(--border);
		margin-bottom: 3em;
	}
	.hero h1 {
		font-size: 4em;
		line-height: 0.95;
		margin-bottom: 0.3em;
		letter-spacing: -0.04em;
	}
	.tagline {
		font-size: 1.1em;
		color: var(--text-muted);
		margin: 0;
		max-width: 400px;
	}
	.section-title {
		font-size: 0.8em;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--text-dim);
		margin-bottom: 1.5em;
	}
	.posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.posts li {
		border-bottom: 1px solid var(--border);
	}
	.posts li a {
		display: block;
		padding: 1.5em 0;
		text-decoration: none;
		transition: background 0.2s;
	}
	.posts li a:hover {
		padding-left: 1em;
		background: var(--bg-surface);
		margin: 0 -1em;
		padding-right: 1em;
		border-radius: var(--radius);
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.8em;
		font-family: var(--font-display);
		font-size: 0.75em;
		color: var(--text-dim);
		margin-bottom: 0.4em;
	}
	.post-title {
		font-size: 1.3em;
		color: var(--text);
		margin: 0 0 0.2em 0;
		font-family: var(--font-display);
	}
	.post-artist {
		font-family: var(--font-display);
		font-size: 0.85em;
		color: var(--text-muted);
		margin: 0 0 0.3em 0;
	}
	.post-description {
		color: var(--text-muted);
		font-size: 0.9em;
		margin: 0;
		line-height: 1.5;
	}
	.view-all {
		display: inline-block;
		margin-top: 2em;
		font-family: var(--font-display);
		font-size: 0.85em;
		color: var(--accent);
	}
	@media (max-width: 720px) {
		.hero h1 { font-size: 2.5em; }
		.hero { padding: 2em 0 2em 0; }
	}
</style>
