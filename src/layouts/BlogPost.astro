---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, artist, album, rating, genre, type } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={720} height={720} src={heroImage} alt={title} />
					</div>
				)}
				<div class="prose">
					<div class="article-header">
						<div class="meta-row">
							<FormattedDate date={pubDate} />
							{type && <span class={`post-type ${type}`}>{type}</span>}
						</div>
						{updatedDate && (
							<p class="updated">Updated <FormattedDate date={updatedDate} /></p>
						)}
						<h1>{title}</h1>
						{artist && (
							<p class="artist-info">{artist}{album ? ` — ${album}` : ''}</p>
						)}
						{rating && (
							<div class="rating-block">
								<span class="rating-number">{rating}</span>
								<span class="rating-max">/10</span>
							</div>
						)}
						{genre && genre.length > 0 && (
							<div class="genre-list">
								{genre.map((g: string) => (
									<span class="genre-tag">{g}</span>
								))}
							</div>
						)}
					</div>
					<hr />
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero-image {
		max-width: 500px;
		margin: 0 auto 2em auto;
	}
	.hero-image img {
		display: block;
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: var(--radius);
		border: 1px solid var(--border);
	}
	.prose {
		max-width: var(--max-width);
		margin: auto;
	}
	.article-header {
		margin-bottom: 1em;
	}
	.meta-row {
		display: flex;
		align-items: center;
		gap: 0.8em;
		font-family: var(--font-display);
		font-size: 0.8em;
		color: var(--text-dim);
		margin-bottom: 0.8em;
	}
	.updated {
		font-family: var(--font-display);
		font-size: 0.75em;
		color: var(--text-dim);
		font-style: italic;
		margin: 0 0 0.5em 0;
	}
	h1 {
		margin-bottom: 0.3em;
		font-size: 2.2em;
	}
	.artist-info {
		font-family: var(--font-display);
		font-size: 1em;
		color: var(--text-muted);
		margin: 0 0 0.8em 0;
	}
	.rating-block {
		font-family: var(--font-display);
		margin-bottom: 1em;
	}
	.rating-number {
		font-size: 2em;
		font-weight: 700;
		color: var(--accent);
	}
	.rating-max {
		font-size: 1em;
		color: var(--text-dim);
	}
	.genre-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3em;
		margin-bottom: 1em;
	}
</style>
