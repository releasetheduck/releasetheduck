---
import { LASTFM_URL } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-content">
		<p class="footer-text">
			&copy; {today.getFullYear()} Release the Duck
		</p>
		<p class="footer-links">
			<a href={LASTFM_URL} target="_blank">Last.fm</a>
			<span class="sep">/</span>
			<a href="/rss.xml">RSS</a>
		</p>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 2em 1.5em;
		margin-top: 4em;
	}
	.footer-content {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.footer-text {
		font-family: var(--font-display);
		font-size: 0.75em;
		color: var(--text-dim);
		margin: 0;
	}
	.footer-links {
		font-family: var(--font-display);
		font-size: 0.75em;
		margin: 0;
	}
	.footer-links a {
		color: var(--text-muted);
		text-decoration: none;
	}
	.footer-links a:hover { color: var(--accent); }
	.sep { color: var(--text-dim); margin: 0 0.5em; }
	@media (max-width: 720px) {
		.footer-content { flex-direction: column; gap: 0.5em; text-align: center; }
	}
</style>
